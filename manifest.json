{
  "manifest_version": 3,
  "name": "Focus Clash",
  "version": "1.0.0",
  "description": "Gamified focus system — compete on real focus, not fake hours. ⚔️",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "windows",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "blocked_sites",
        "enabled": false,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/tracker.js", "content/overlay.js", "content/anti-cheat-popup.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.css", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
